import pygame
import socket
import pickle

WIDTH, HEIGHT = 1200, 750
BG_COLOR = (10, 10, 18)
P1_COLOR = (0, 255, 255)
P2_COLOR = (255, 0, 255)

class Network:
    def __init__(self):
        self.client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.server = "127.0.0.1" 
        self.port = 5555
        self.p = self.connect()

    def connect(self):
        try:
            self.client.connect((self.server, self.port))
            return pickle.loads(self.client.recv(4096))
        except: return None

    def send(self, data):
        try:
            self.client.send(pickle.dumps(data))
            return pickle.loads(self.client.recv(4096))
        except: return None

def draw_neon_rect(surf, color, rect):
    pygame.draw.rect(surf, color, rect, border_radius=8)
    for i in range(1, 3):
        pygame.draw.rect(surf, color, rect.inflate(i*3, i*3), 1, border_radius=8)

def main():
    pygame.init()
    screen = pygame.display.set_mode((WIDTH, HEIGHT))
    clock = pygame.time.Clock()
    font_score = pygame.font.SysFont("Consolas", 60, bold=True)
    font_msg = pygame.font.SysFont("Consolas", 30)

    n = Network()
    if n.p is None: return
        
    my_y = 315 

    while True:
        game_state = n.send(my_y)
        if not game_state: continue
            
        screen.fill(BG_COLOR)
        
        # Draw Score
        s1 = font_score.render(str(game_state["p1_score"]), True, P1_COLOR)
        s2 = font_score.render(str(game_state["p2_score"]), True, P2_COLOR)
        screen.blit(s1, (WIDTH//4, 50))
        screen.blit(s2, (WIDTH*3//4, 50))

        # Waiting Message
        if not game_state["active"]:
            msg = font_msg.render("WAITING FOR BOTH PLAYERS...", True, (255, 255, 255))
            screen.blit(msg, (WIDTH//2 - 200, HEIGHT//2 + 50))

        # Draw Paddles
        draw_neon_rect(screen, P1_COLOR, pygame.Rect(40, game_state["p1_y"], 15, 120))
        draw_neon_rect(screen, P2_COLOR, pygame.Rect(WIDTH-55, game_state["p2_y"], 15, 120))

        # Draw Ball
        bx, by = game_state["ball_pos"]
        pygame.draw.circle(screen, (255, 255, 255), (int(bx), int(by)), 10)

        for event in pygame.event.get():
            if event.type == pygame.QUIT: return

        keys = pygame.key.get_pressed()
        if keys[pygame.K_w] and my_y > 0: my_y -= 10
        if keys[pygame.K_s] and my_y < HEIGHT - 120: my_y += 10

        pygame.display.flip()
        clock.tick(60)

if __name__ == "__main__":
    main()

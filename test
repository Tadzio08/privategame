import pygame
import socket
import pickle

# --- CONFIG ---
WIDTH, HEIGHT = 1200, 750
BG_COLOR = (5, 5, 12)
P1_COLOR = (0, 255, 255)
P2_COLOR = (255, 0, 255)

class Network:
    def __init__(self):
        self.client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.server = "127.0.0.1" 
        self.port = 5555
        self.p = self.connect()

    def connect(self):
        try:
            self.client.connect((self.server, self.port))
            return pickle.loads(self.client.recv(4096))
        except: return None

    def send(self, data):
        try:
            self.client.send(pickle.dumps(data))
            return pickle.loads(self.client.recv(4096))
        except: return None

def draw_neon_paddle(surf, color, rect):
    # Layered glow
    for i in range(8, 0, -1):
        glow_rect = rect.inflate(i*2, i*2)
        s = pygame.Surface((glow_rect.width, glow_rect.height), pygame.SRCALPHA)
        pygame.draw.rect(s, (*color, 50//i), (0, 0, glow_rect.width, glow_rect.height), border_radius=8)
        surf.blit(s, glow_rect.topleft)
    pygame.draw.rect(surf, (255, 255, 255), rect, border_radius=8) # White core

def main():
    pygame.init()
    screen = pygame.display.set_mode((WIDTH, HEIGHT))
    clock = pygame.time.Clock()
    n = Network()
    if n.p is None: return
    my_y = 315

    while True:
        game_state = n.send(my_y)
        if not game_state: continue

        screen.fill(BG_COLOR)

        # Draw Atari Bricks
        for b in game_state["bricks"]:
            if b[4]:
                pygame.draw.rect(screen, (255, 200, 0), (b[0], b[1], b[2], b[3]), border_radius=4)
                pygame.draw.rect(screen, (255, 255, 255), (b[0], b[1], b[2], b[3]), 1, border_radius=4)

        # Draw Ball with Trail
        bx, by = game_state["ball_pos"]
        pygame.draw.circle(screen, (255, 255, 255), (int(bx), int(by)), 12)
        for i in range(1, 5):
            pygame.draw.circle(screen, (255, 255, 255, 100), (int(bx - game_state["ball_vel"][0]*i), int(by - game_state["ball_vel"][1]*i)), 12 - i*2)

        # Draw Paddles
        draw_neon_paddle(screen, P1_COLOR, pygame.Rect(40, game_state["p1_y"], 15, game_state["p1_h"]))
        draw_neon_paddle(screen, P2_COLOR, pygame.Rect(WIDTH-55, game_state["p2_y"], 15, game_state["p2_h"]))

        # Input
        keys = pygame.key.get_pressed()
        if keys[pygame.K_w] and my_y > 0: my_y -= 12
        if keys[pygame.K_s] and my_y < HEIGHT - game_state.get("p1_h", 120): my_y += 12

        for event in pygame.event.get():
            if event.type == pygame.QUIT: return

        pygame.display.flip()
        clock.tick(60)

if __name__ == "__main__":
    main()

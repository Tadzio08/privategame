import pygame
import socket
import pickle

WIDTH, HEIGHT = 1200, 750

class Network:
    def __init__(self):
        self.client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.server = "127.0.0.1"
        self.port = 5555
        self.p = self.connect()

    def connect(self):
        try:
            self.client.connect((self.server, self.port)); return pickle.loads(self.client.recv(4096))
        except: return None

    def send(self, data):
        try:
            self.client.send(pickle.dumps(data))
            resp = self.client.recv(4096)
            if not resp: return "DISCONNECTED"
            return pickle.loads(resp)
        except: return "DISCONNECTED"

def main():
    pygame.init()
    screen = pygame.display.set_mode((WIDTH, HEIGHT))
    clock = pygame.time.Clock()
    f_lg = pygame.font.SysFont("Consolas", 60, bold=True)
    f_sm = pygame.font.SysFont("Consolas", 20)

    n = Network()
    if n.p is None: return
    my_y, voted = 315, False

    while True:
        input_data = my_y
        if not voted:
            keys = pygame.key.get_pressed()
            if keys[pygame.K_1]: input_data = "NORMAL"; voted = True
            if keys[pygame.K_2]: input_data = "CHAOS"; voted = True

        game_state = n.send(input_data)

        if game_state == "DISCONNECTED":
            screen.fill((0,0,0))
            screen.blit(f_lg.render("KICKED / DISCONNECTED", True, (255,0,0)), (WIDTH//2-350, HEIGHT//2-50))
            screen.blit(f_sm.render("Press ESC to Exit", True, (200,200,200)), (WIDTH//2-100, HEIGHT//2+50))
            pygame.display.flip()
            for e in pygame.event.get():
                if e.type == pygame.QUIT or (e.type == pygame.KEYDOWN and e.key == pygame.K_ESCAPE): return
            continue

        screen.fill((10, 10, 25))

        if not game_state["active"]:
            screen.blit(f_lg.render("WAITING FOR PLAYERS...", True, (255,255,255)), (WIDTH//2-350, HEIGHT//2))
        elif game_state["mode"] == "voting":
            screen.blit(f_lg.render("VOTE: [1] OR [2]", True, (255,255,255)), (WIDTH//2-250, HEIGHT//2))
        else:
            for b in game_state["bricks"]:
                if b[4]: pygame.draw.rect(screen, (50, 50, 70), (b[0], b[1], b[2], b[3]), border_radius=5)
            if game_state["p1_wall"]: pygame.draw.rect(screen, (0, 255, 0), (0, 0, 10, HEIGHT))
            if game_state["p2_wall"]: pygame.draw.rect(screen, (0, 255, 0), (WIDTH-10, 0, 10, HEIGHT))
            for c in game_state["crates"]:
                pygame.draw.rect(screen, (255, 255, 0), (c[0], c[1], 35, 35), border_radius=5)
                screen.blit(f_sm.render(c[2][0], True, (0,0,0)), (c[0]+12, c[1]+8))
            
            bx, by = game_state["ball_pos"]
            pygame.draw.circle(screen, (255, 255, 255), (int(bx), int(by)), 12)
            for fb in game_state["fake_balls"]: pygame.draw.circle(screen, (80, 80, 90), (int(fb[0][0]), int(fb[0][1])), 10)
            
            pygame.draw.rect(screen, (0, 255, 255), (40, game_state["p1_y"], 15, game_state["p1_h"]), border_radius=5)
            pygame.draw.rect(screen, (255, 0, 255), (WIDTH-55, game_state["p2_y"], 15, game_state["p2_h"]), border_radius=5)
            screen.blit(f_lg.render(str(game_state["p1_score"]), True, (0, 255, 255)), (WIDTH//4, 50))
            screen.blit(f_lg.render(str(game_state["p2_score"]), True, (255, 0, 255)), (WIDTH*3//4, 50))

        for i in range(0, HEIGHT, 4): pygame.draw.line(screen, (0,0,0), (0,i), (WIDTH, i), 1)
        for e in pygame.event.get():
            if e.type == pygame.QUIT: return

        keys = pygame.key.get_pressed()
        if keys[pygame.K_w] and my_y > 0: my_y -= 12
        if keys[pygame.K_s] and my_y < HEIGHT - 100: my_y += 12
        pygame.display.flip()
        clock.tick(60)

if __name__ == "__main__":
    main()

import pygame
import socket
import pickle

WIDTH, HEIGHT = 1200, 750
BG_COLOR = (10, 10, 25)

class Network:
    def __init__(self):
        self.client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.server = "127.0.0.1" 
        self.port = 5555
        self.p = self.connect()

    def connect(self):
        try:
            self.client.connect((self.server, self.port))
            return pickle.loads(self.client.recv(4096))
        except: return None

    def send(self, data):
        try:
            self.client.send(pickle.dumps(data))
            return pickle.loads(self.client.recv(4096))
        except: return None

def draw_arcade_effects(screen):
    # Scanlines for that "Old TV" look
    for i in range(0, HEIGHT, 4):
        pygame.draw.line(screen, (0, 0, 0, 50), (0, i), (WIDTH, i))

def main():
    pygame.init()
    screen = pygame.display.set_mode((WIDTH, HEIGHT))
    clock = pygame.time.Clock()
    font_lg = pygame.font.SysFont("Consolas", 80, bold=True)
    font_sm = pygame.font.SysFont("Consolas", 25)

    n = Network()
    if n.p is None: return
    my_y, voted = 315, False

    while True:
        # 1. SEND DATA
        input_data = my_y
        if not voted:
            keys = pygame.key.get_pressed()
            if keys[pygame.K_1]: input_data = "NORMAL"; voted = True
            if keys[pygame.K_2]: input_data = "CHAOS"; voted = True

        game_state = n.send(input_data)
        if not game_state: continue

        screen.fill(BG_COLOR)

        # 2. RENDER MODES
        if game_state["mode"] == "voting":
            msg = font_lg.render("VOTE GAMEMODE", True, (255, 255, 255))
            screen.blit(msg, (WIDTH//2 - 300, 200))
            sub = font_sm.render("[1] NORMAL PONG    [2] CHAOS SPEED", True, (0, 255, 255))
            screen.blit(sub, (WIDTH//2 - 220, 350))
            if voted:
                wait = font_sm.render("WAITING FOR OTHER PLAYER...", True, (255, 255, 0))
                screen.blit(wait, (WIDTH//2 - 180, 500))

        else:
            # Draw Bricks (Solid/Dull)
            for b in game_state["bricks"]:
                if b[4]: pygame.draw.rect(screen, (60, 60, 80), (b[0], b[1], b[2], b[3]))

            # Draw Crates (Bright/Glowing)
            for c in game_state["crates"]:
                color = (255, 255, 0) # Bright Yellow
                pygame.draw.rect(screen, color, (c[0], c[1], 30, 30))
                pygame.draw.rect(screen, (255, 255, 255), (c[0], c[1], 30, 30), 2) # White border

            # Draw Scores
            s1 = font_lg.render(str(game_state["p1_score"]), True, (0, 255, 255))
            screen.blit(s1, (WIDTH//4, 50))
            s2 = font_lg.render(str(game_state["p2_score"]), True, (255, 0, 255))
            screen.blit(s2, (WIDTH*3//4, 50))

            # Draw Ball & Paddles
            bx, by = game_state["ball_pos"]
            pygame.draw.circle(screen, (255, 255, 255), (int(bx), int(by)), 12)
            pygame.draw.rect(screen, (0, 255, 255), (40, game_state["p1_y"], 15, game_state["p1_h"]))
            pygame.draw.rect(screen, (255, 0, 255), (WIDTH-55, game_state["p2_y"], 15, game_state["p2_h"]))

        draw_arcade_effects(screen)
        
        # 3. MOVEMENT
        keys = pygame.key.get_pressed()
        if keys[pygame.K_w] and my_y > 0: my_y -= 12
        if keys[pygame.K_s] and my_y < HEIGHT - 120: my_y += 12

        for event in pygame.event.get():
            if event.type == pygame.QUIT: return

        pygame.display.flip()
        clock.tick(60)

if __name__ == "__main__":
    main()
